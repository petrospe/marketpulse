# Database driver: omit all DB_* vars to use SQLite (default).
# Set DB_DRIVER=mysql and the variables below to use MySQL instead.

# DB_DRIVER=sqlite
# SQLITE_PATH=./data/marketpulse.sqlite

# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=marketpulse

# API
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
ALLOW_REGISTRATION=false
